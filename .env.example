# Stripe — get from dashboard.stripe.com
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY
# Run: stripe listen --forward-to localhost:3002/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
# Local dev: http://localhost:3000 | Production: https://badgrtech.com
VITE_APP_URL=http://localhost:3000

# Resend is the production-ready sender for the free Lighthouse audit form.
RESEND_API_KEY=
RESEND_FROM=BADGRTechnologies <onboarding@resend.dev>
SCAN_REQUEST_TO=antgrant4781@proton.me

# Optional local SMTP fallback settings for Proton Mail Bridge.
# Copy to .env.local and fill SMTP_PASS with the password shown in Proton Bridge.
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_REQUIRE_TLS=true
SMTP_REJECT_UNAUTHORIZED=false
SMTP_SECURE=false
SMTP_USER=your_proton_bridge_smtp_username
SMTP_PASS=
SCAN_REQUEST_FROM=antgrant4781@proton.me
